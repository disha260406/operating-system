#include <stdio.h>
#include <unistd.h>
#include <fcntl.h>
#include <stdlib.h>
#include <string.h>

int main() {
    int fd[2];
    pid_t pid;
    char write_msg[] = "Hello from Parent";
    char read_msg[100];

    // -------- PIPE CREATION --------
    if (pipe(fd) == -1) {
        printf("Pipe failed\n");
        return 1;
    }

    // -------- FORK --------
    pid = fork();

    if (pid < 0) {
        printf("Fork failed\n");
        return 1;
    }

    else if (pid == 0) {
        // -------- CHILD PROCESS --------
        printf("\n--- Child Process ---\n");

        // Read from pipe
        read(fd[0], read_msg, sizeof(read_msg));
        printf("Child received: %s\n", read_msg);

        // Display process ID
        printf("Child PID: %d\n", getpid());

        // EXEC example (runs 'ls')
        printf("Executing 'ls' command:\n");
        execl("/bin/ls", "ls", NULL);

    } else {
        // -------- PARENT PROCESS --------
        printf("\n--- Parent Process ---\n");

        // Write to pipe
        write(fd[1], write_msg, strlen(write_msg)+1);

        // File handling
        int file = open("test.txt", O_CREAT | O_WRONLY, 0644);
        write(file, "Linux System Programming\n", 25);
        close(file);

        printf("File created and written successfully\n");

        // Display process ID
        printf("Parent PID: %d\n", getpid());
    }

    return 0;
}
