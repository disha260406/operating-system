#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

int main() {
    char command[100];

    while (1) {
        printf("\nFedoraShell> ");
        fgets(command, sizeof(command), stdin);

        // Remove newline
        command[strcspn(command, "\n")] = 0;

        // Exit condition
        if (strcmp(command, "exit") == 0) {
            printf("Exiting shell...\n");
            break;
        }

        // PWD command
        else if (strcmp(command, "pwd") == 0) {
            char cwd[100];
            getcwd(cwd, sizeof(cwd));
            printf("Current Directory: %s\n", cwd);
        }

        // CD command
        else if (strncmp(command, "cd ", 3) == 0) {
            char *path = command + 3;
            if (chdir(path) != 0) {
                perror("cd failed");
            }
        }

        // MKDIR command
        else if (strncmp(command, "mkdir ", 6) == 0) {
            char *dir = command + 6;
            if (mkdir(dir, 0777) != 0) {
                perror("mkdir failed");
            } else {
                printf("Directory created\n");
            }
        }

        // RM command
        else if (strncmp(command, "rm ", 3) == 0) {
            char *file = command + 3;
            if (remove(file) != 0) {
                perror("rm failed");
            } else {
                printf("File deleted\n");
            }
        }

        // LS command (using system call)
        else if (strcmp(command, "ls") == 0) {
            system("ls");
        }

        // Unknown command → pass to system
        else {
            system(command);
        }
    }

    return 0;
}
